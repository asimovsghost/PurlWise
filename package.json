{
  "name": "purlwise",
  "version": "1.0.0",
  "description": "Premium Interactive Knitting Progress Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --win",
    "build:all": "powershell ./build.ps1"
  },
  "keywords": [
    "knitting",
    "progress",
    "tracker"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "devDependencies": {
    "electron": "^25.3.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1"
  },
  "build": {
    "appId": "com.purlwise.desktop",
    "productName": "PurlWise",
    "directories": {
      "output": "dist-installer"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
